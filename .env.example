# Copy this file to .env and fill in values
# .env is gitignored — never commit your real .env

# Database (leave blank to use local SQLite)
DATABASE_URL=

# College Football Data API (free key — get at https://collegefootballdata.com/key)
CFBD_API_KEY=

# Season settings
MLB_SEASON=2025
NFL_SEASON=2024
NCAA_FB_SEASON=2024
NCAA_BB_SEASON=2024-25
